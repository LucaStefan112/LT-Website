---
import "../styles/global.css";
import { getContent, resolveLocale, localeMeta, localePath, stripLocale } from "../content/i18n";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description: string;
  path: string; // e.g. "/", "/services", "/ro/services"
  ogImage?: string;
  ogType?: string; // "website" (default) or "article" for insight posts
}
const {
  title,
  description,
  path,
  ogImage = "/og-image.png",
  ogType = "website",
} = Astro.props;

const locale = resolveLocale(Astro.url.pathname);
const { site } = getContent(locale);
const { htmlLang, ogLocale } = localeMeta[locale];

// site.url has no trailing slash, and every route emits a slash-free canonical
// (matching the sitemap and build.format: "file"). Special-case "/" so the home
// canonical is the bare origin too, rather than URL()'s forced trailing slash.
const toAbs = (p: string) => (p === "/" ? site.url : new URL(p, site.url).href);
const canonical = toAbs(path);
// hreflang alternates: this page in each language, x-default = English.
const barePath = stripLocale(path);
const showAlternates = barePath !== "/404";
const alternates = [
  { hreflang: "en", href: toAbs(localePath("en", barePath)) },
  { hreflang: "ro", href: toAbs(localePath("ro", barePath)) },
  { hreflang: "x-default", href: toAbs(localePath("en", barePath)) },
];
const ogImageUrl = new URL(ogImage, site.url).href;
const logoUrl = new URL("/brand/lt-logo-primary.png", site.url).href;

const orgSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: site.name,
  url: site.url,
  logo: logoUrl,
  image: ogImageUrl,
  description: site.description,
  email: site.email,
  telephone: site.phone,
  slogan: site.tagline,
  founder: { "@type": "Person", name: site.founder },
};
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {showAlternates && alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}
    <meta name="theme-color" content="#ffffff" />
    <meta name="color-scheme" content="light" />
    <meta name="generator" content={Astro.generator} />

    <!-- Avoid a flash of hidden content: mark JS available before paint -->
    <script is:inline>
      document.documentElement.classList.add("js");
    </script>

    <!-- Preload the single self-hosted font file (no layout shift) -->
    <link
      rel="preload"
      href="/fonts/archivo-variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />

    <!-- Icons / favicons -->
    <link rel="icon" type="image/png" sizes="32x32" href="/brand/lt-favicon-32.png" />
    <link rel="icon" type="image/png" sizes="64x64" href="/brand/lt-favicon-64.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/brand/lt-apple-touch-180.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${site.name} — ${site.tagline}`} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <script
      type="application/ld+json"
      set:html={JSON.stringify(orgSchema)}
    />
  </head>

  <body>
    <a class="skip-link" href="#main">{locale === "ro" ? "Sari la conținut" : "Skip to content"}</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />

    <script>
      import "../scripts/ui.ts";
    </script>
  </body>
</html>
