---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { getContent } from "../../content/i18n";

const { testimonials, testimonialsMeta } = getContent(Astro.url.pathname);

/* Renders ONLY when there is at least one real, permissioned testimonial.
   While `testimonials` is empty, this section outputs nothing — no empty box,
   no placeholder quote. Add real quotes in src/content/site.ts (`testimonials`)
   to make it appear. See README. */
const hasAny = testimonials.length > 0;
---

{
  hasAny && (
    <Section variant="bone" labelledby="testimonials-heading">
      <Container>
        <SectionHeader
          eyebrow={testimonialsMeta.eyebrow}
          title={testimonialsMeta.heading}
          id="testimonials-heading"
        />
        <ul class="testimonials-grid" role="list">
          {testimonials.map((t, i) => (
            <li class="card testimonial reveal" style={`--reveal-delay:${(i % 2) * 90}ms`}>
              <blockquote class="testimonial-quote">{t.quote}</blockquote>
              <div class="testimonial-cite">
                <span class="testimonial-name">{t.name}</span>
                <span class="testimonial-role">
                  {t.role}
                  {t.company ? `, ${t.company}` : ""}
                </span>
              </div>
            </li>
          ))}
        </ul>
      </Container>
    </Section>
  )
}

<style>
  .testimonials-grid {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }
  @media (min-width: 768px) {
    .testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .testimonial {
    display: flex;
    flex-direction: column;
  }
  .testimonial-quote {
    margin: 0 0 1.5rem;
    color: var(--color-ink);
    font-size: 1.1875rem;
    line-height: 1.5;
    font-weight: 500;
    letter-spacing: -0.005em;
  }
  .testimonial-quote::before {
    content: "\201C";
    color: var(--color-steel);
    font-weight: 700;
    margin-right: 0.1em;
  }
  .testimonial-cite {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    margin-top: auto;
  }
  .testimonial-name {
    color: var(--color-ink);
    font-weight: 600;
    font-size: 1rem;
  }
  .testimonial-role {
    color: var(--color-muted);
    font-size: 0.9375rem;
  }
</style>
