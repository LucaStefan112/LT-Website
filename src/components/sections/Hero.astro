---
import Container from "../ui/Container.astro";
import Button from "../ui/Button.astro";
import { getContent } from "../../content/i18n";

const { hero } = getContent(Astro.url.pathname);
---

<section class="hero bg-paper" aria-labelledby="hero-heading">
  <!-- Extremely faint ascending chevron — echoes the logo's rising "T".
       Decorative only; low opacity Deep Blue on Paper (brief §3.4). -->
  <svg
    class="hero-motif"
    aria-hidden="true"
    viewBox="0 0 600 600"
    preserveAspectRatio="xMidYMid meet"
  >
    <path
      d="M60 470 L300 120 L540 470"
      fill="none"
      stroke="currentColor"
      stroke-width="10"
      stroke-linecap="round"
      stroke-linejoin="round"
    ></path>
  </svg>

  <Container>
    <div class="hero-content measure-wide">
      {/* Eyebrow, rule and the H1 (the LCP element) render at full opacity
          from first paint — they are NOT faded in, so LCP is not deferred.
          Only the supporting content below animates in. */}
      <p class="eyebrow">{hero.eyebrow}</p>
      <span class="rule" aria-hidden="true"></span>

      <h1 id="hero-heading" class="display hero-heading">
        {hero.headline}
      </h1>

      <p class="lead hero-subhead hero-in" style="--d:80ms">
        {hero.subhead}
      </p>

      <div class="hero-actions hero-in" style="--d:180ms">
        <Button href={hero.primaryCta.href} external={hero.primaryCta.external}>
          {hero.primaryCta.label}
        </Button>
        <a href={hero.secondaryCta.href} class="link-arrow hero-secondary">
          {hero.secondaryCta.label}
          <span class="arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path
                d="M3 8h9M8.5 4l3.5 4-3.5 4"
                stroke="currentColor"
                stroke-width="1.6"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </span>
        </a>
      </div>

      <p class="hero-trust hero-in" style="--d:280ms">{hero.trustLine}</p>
    </div>
  </Container>
</section>

<style>
  .hero {
    position: relative;
    overflow: hidden;
    padding-top: clamp(6.5rem, 12vw, 9.5rem);
    padding-bottom: clamp(4rem, 9vw, 7rem);
  }

  .hero-motif {
    position: absolute;
    top: 50%;
    right: -8%;
    transform: translateY(-50%);
    width: clamp(360px, 45vw, 680px);
    height: auto;
    color: var(--color-ink);
    opacity: 0.04;
    pointer-events: none;
  }
  @media (max-width: 767px) {
    .hero-motif {
      right: -30%;
      opacity: 0.03;
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-heading {
    margin-top: 1.5rem;
  }
  .hero-subhead {
    margin-top: 1.5rem;
    max-width: 40rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 1.75rem;
    margin-top: 2.25rem;
  }
  .hero-secondary {
    min-height: 2.875rem;
    padding-block: 0.5rem;
  }

  .hero-trust {
    margin-top: 2rem;
    font-size: 0.875rem;
    letter-spacing: 0.02em;
    color: var(--color-muted);
  }

  /* Orchestrated entrance — runs once on load, JS + motion-safe only */
  @media (prefers-reduced-motion: no-preference) {
    :global(html.js) .hero-in {
      opacity: 0;
      transform: translateY(18px);
      animation: heroIn 0.7s var(--ease-out-soft) forwards;
      animation-delay: var(--d, 0ms);
    }
  }
  @keyframes heroIn {
    to {
      opacity: 1;
      transform: none;
    }
  }
</style>
