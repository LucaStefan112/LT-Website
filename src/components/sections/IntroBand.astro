---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import { intro } from "../../content/site";
---

<Section variant="bone" tight labelledby="intro-heading">
  <Container>
    <div class="intro-grid">
      <div class="intro-kicker reveal">
        <h2 id="intro-heading" class="eyebrow">{intro.eyebrow}</h2>
        <span class="rule" aria-hidden="true"></span>
      </div>
      <p class="intro-copy reveal" style="--reveal-delay:80ms">
        {intro.body}
      </p>
    </div>
  </Container>
</Section>

<style>
  .intro-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem;
  }
  @media (min-width: 900px) {
    .intro-grid {
      grid-template-columns: minmax(12rem, 16rem) 1fr;
      gap: clamp(2rem, 6vw, 5rem);
      align-items: start;
    }
  }
  .intro-copy {
    color: var(--color-ink);
    font-size: clamp(1.375rem, 2.6vw, 1.875rem); /* 22 → 30 */
    line-height: 1.4;
    font-weight: 500;
    letter-spacing: -0.01em;
    max-width: 34ch;
    text-wrap: pretty;
  }
</style>
