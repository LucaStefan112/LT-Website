---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import Button from "../ui/Button.astro";
import { services } from "../../content/site";

interface Props {
  showHeader?: boolean;
  variant?: "paper" | "bone";
}
const { showHeader = true, variant = "bone" } = Astro.props;
---

<Section id="services" variant={variant} labelledby="services-heading">
  <Container>
    {
      showHeader ? (
        <SectionHeader
          eyebrow={services.eyebrow}
          title="One partner, end to end."
          intro={services.intro}
          id="services-heading"
        />
      ) : (
        /* Reused under a page <h1> (e.g. /services): keep a real h2 so heading
           levels don't skip h1 -> h3, but hide it visually. */
        <h2 id="services-heading" class="sr-only">
          What we do
        </h2>
      )
    }

    <ul class:list={["services-grid", { "services-grid--top": !showHeader }]} role="list">
      {
        services.items.map((item, i) => (
          <li class="service reveal" style={`--reveal-delay:${(i % 2) * 90}ms`}>
            <span class="service-rule" aria-hidden="true" />
            <h3 class="service-title">{item.title}</h3>
            <p class="service-body">{item.body}</p>
            <p class="service-deliv-label">What you get</p>
            <ul class="service-deliverables" role="list">
              {item.deliverables.map((d) => (
                <li>{d}</li>
              ))}
            </ul>
          </li>
        ))
      }
    </ul>

    <div class="services-ai reveal">
      <div class="services-ai-intro">
        <p class="eyebrow services-ai-eyebrow">{services.ai.eyebrow}</p>
        <h3 class="services-ai-title">{services.ai.title}</h3>
        <p class="services-ai-body">{services.ai.body}</p>
      </div>

      <ul class="services-ai-points" role="list">
        {
          services.ai.points.map((p) => (
            <li>
              <h4 class="services-ai-point-title">{p.title}</h4>
              <p class="services-ai-point-body">{p.body}</p>
            </li>
          ))
        }
      </ul>

      <div class="services-ai-foot">
        <p class="services-ai-note">{services.ai.note}</p>
        <Button href={services.ai.cta.href} variant="ghost" withArrow>
          {services.ai.cta.label}
        </Button>
      </div>
    </div>
  </Container>
</Section>

<style>
  .services-grid {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.75rem) 0 0;
    padding: 0;
  }
  .services-grid.services-grid--top {
    margin-top: 0;
  }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3rem) clamp(2rem, 6vw, 4.5rem);
  }
  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .service {
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    position: relative;
  }
  .service-rule {
    position: absolute;
    top: -1px;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .service-title {
    font-size: 1.375rem; /* 22 */
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    margin-bottom: 0.75rem;
  }
  .service-body {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 42ch;
  }
  .service-deliv-label {
    margin-top: 1.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-ink);
  }
  .service-deliverables {
    list-style: none;
    margin: 0.75rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    max-width: 42ch;
  }
  .service-deliverables li {
    position: relative;
    padding-left: 1.5rem;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.45;
  }
  .service-deliverables li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 0.75rem;
    height: 2px;
    background-color: var(--color-steel);
  }

  /* Featured AI specialty block */
  .services-ai {
    margin-top: clamp(3rem, 6vw, 4.5rem);
    padding: clamp(1.75rem, 4vw, 3rem);
    border-radius: 18px;
    border: 1px solid var(--color-line);
    border-left: 3px solid var(--color-steel);
    background-color: color-mix(in srgb, var(--color-steel) 5%, var(--color-paper));
  }
  .services-ai-eyebrow {
    color: var(--color-steel);
  }
  .services-ai-title {
    margin-top: 0.75rem;
    font-size: clamp(1.5rem, 3vw, 1.875rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--color-ink);
    max-width: 24ch;
  }
  .services-ai-body {
    margin-top: 1rem;
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 62ch;
  }
  .services-ai-points {
    list-style: none;
    margin: clamp(1.75rem, 3vw, 2.5rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 2.5rem;
  }
  @media (min-width: 768px) {
    .services-ai-points {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .services-ai-point-title {
    display: inline-block;
    padding-top: 0.875rem;
    border-top: 2px solid var(--color-steel);
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 0.5rem;
  }
  .services-ai-point-body {
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.55;
  }
  .services-ai-foot {
    margin-top: clamp(1.75rem, 3vw, 2.5rem);
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    align-items: flex-start;
  }
  @media (min-width: 640px) {
    .services-ai-foot {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }
  }
  .services-ai-note {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.9375rem;
    line-height: 1.5;
    max-width: 48ch;
  }
  .services-ai-foot :global(.btn) {
    flex-shrink: 0;
  }
</style>
