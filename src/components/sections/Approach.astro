---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import SectionHeader from "../ui/SectionHeader.astro";
import { approach } from "../../content/site";
---

<Section id="approach" variant="bone" labelledby="approach-heading">
  <Container>
    <SectionHeader
      eyebrow={approach.eyebrow}
      title="A disciplined path to outcomes."
      intro={approach.intro}
      id="approach-heading"
    />

    <ol class="steps" role="list">
      {
        approach.steps.map((step, i) => (
          <li class="step reveal" style={`--reveal-delay:${i * 90}ms`}>
            <span class="step-rule" aria-hidden="true" />
            <span class="step-n" aria-hidden="true">
              {step.n}
            </span>
            <h3 class="step-title">
              <span class="sr-only">{`Step ${i + 1}: `}</span>
              {step.title}
            </h3>
            <p class="step-body">{step.body}</p>
            <p class="step-output">
              <span class="step-output-label">You leave with</span>
              {step.output}
            </p>
          </li>
        ))
      }
    </ol>
  </Container>
</Section>

<style>
  .steps {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.75rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.25rem;
    counter-reset: step;
  }
  @media (min-width: 640px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 2.5rem clamp(2rem, 5vw, 3.5rem);
    }
  }
  @media (min-width: 1024px) {
    .steps {
      grid-template-columns: repeat(4, 1fr);
      gap: clamp(1.5rem, 3vw, 2.5rem);
    }
  }
  .step {
    position: relative;
    padding-top: 1.75rem;
    border-top: 1px solid var(--color-line);
  }
  .step-rule {
    position: absolute;
    top: -1px;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .step-n {
    display: block;
    font-size: 2rem;
    font-weight: 600;
    line-height: 1;
    color: var(--color-steel);
    letter-spacing: -0.02em;
    margin-bottom: 1rem;
    font-variant-numeric: tabular-nums;
  }
  .step-title {
    font-size: 1.25rem; /* 20 */
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    margin-bottom: 0.625rem;
  }
  .step-body {
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.55;
  }
  .step-output {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-line);
    color: var(--color-ink);
    font-size: 0.9375rem;
    line-height: 1.5;
  }
  .step-output-label {
    display: block;
    margin-bottom: 0.25rem;
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-steel);
  }
</style>
