---
import Section from "../ui/Section.astro";
import Container from "../ui/Container.astro";
import Reveal from "../ui/Reveal.astro";
import { clients } from "../../content/site";
---

<Section variant="paper" tight labelledby="clients-heading">
  <Container>
    <div class="clients-grid">
      <Reveal class="clients-copy">
        <h2 id="clients-heading" class="eyebrow">{clients.eyebrow}</h2>
        <span class="rule" aria-hidden="true"></span>
        <p class="clients-body">{clients.body}</p>
      </Reveal>

      <Reveal delay={90}>
        <ul role="list" class="levels">
          {
            clients.levels.map((level) => (
              <li class="level">
                <span class="level-rule" aria-hidden="true" />
                <h3 class="level-role">{level.role}</h3>
                <p class="level-detail">{level.detail}</p>
              </li>
            ))
          }
        </ul>
      </Reveal>
    </div>
  </Container>
</Section>

<style>
  .clients-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .clients-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  .clients-body {
    margin-top: 1.5rem;
    color: var(--color-muted);
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 42ch;
  }

  .levels {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
  }
  .level {
    position: relative;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
  }
  .level-rule {
    position: absolute;
    top: -1px;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .level-role {
    font-size: 1.1875rem; /* 19 */
    font-weight: 600;
    color: var(--color-ink);
    letter-spacing: -0.01em;
    margin-bottom: 0.4rem;
  }
  .level-detail {
    color: var(--color-muted);
    font-size: 1rem;
    line-height: 1.5;
    max-width: 42ch;
  }
</style>
