---
/* Spaced-caps kicker + the 2px Steel rule beneath — the brand signature. */
interface Props {
  text: string;
  class?: string;
}
const { text, class: className = "" } = Astro.props;
---

<div class:list={["flex flex-col", className]}>
  <span class="eyebrow">{text}</span>
  <span class="rule" aria-hidden="true"></span>
</div>
