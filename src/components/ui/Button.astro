---
/* Primary (solid Steel) or ghost secondary action. Renders an anchor. */
interface Props {
  href: string;
  variant?: "primary" | "ghost";
  withArrow?: boolean;
  external?: boolean; // opens in a new tab (e.g. a booking link)
  class?: string;
  "aria-label"?: string;
  plausibleEvent?: string; // fires a named Plausible event on click
}
const {
  href,
  variant = "primary",
  withArrow = false,
  external = false,
  class: className = "",
  "aria-label": ariaLabel,
  plausibleEvent,
} = Astro.props;

const isInternalAnchor = href.startsWith("#") || href.startsWith("/#");
const shouldPrefetch = !external && !isInternalAnchor;
// Plausible reads the event name from a CSS class; spaces are encoded as "+".
// Using the class mechanism (not a manual call) so the event is delivered even
// when the click navigates the page away.
const plausibleClass = plausibleEvent
  ? `plausible-event-name=${plausibleEvent.replace(/ /g, "+")}`
  : undefined;
---

<a
  href={href}
  aria-label={ariaLabel}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
  class:list={[
    "btn",
    variant === "primary" ? "btn-primary" : "btn-ghost",
    plausibleClass,
    className,
  ]}
  data-astro-prefetch={shouldPrefetch ? "" : undefined}
>
  <slot />
  {
    withArrow && (
      <span class="arrow" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
          <path
            d="M3 8h9M8.5 4l3.5 4-3.5 4"
            stroke="currentColor"
            stroke-width="1.6"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
        </svg>
      </span>
    )
  }
</a>
