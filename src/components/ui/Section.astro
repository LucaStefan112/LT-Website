---
/* A page section with consistent vertical rhythm and a background variant.
   variant: "paper" (white) | "bone" (warm) | "ink" (Deep Blue band, reversed).
   Alternate paper/bone down the page for gentle rhythm (brief §3.1). */
interface Props {
  id?: string;
  variant?: "paper" | "bone" | "ink";
  tight?: boolean;
  class?: string;
  labelledby?: string;
}
const {
  id,
  variant = "paper",
  tight = false,
  class: className = "",
  labelledby,
} = Astro.props;

const bg =
  variant === "ink"
    ? "band-ink on-dark"
    : variant === "bone"
      ? "bg-bone"
      : "bg-paper";
---

<section
  id={id}
  aria-labelledby={labelledby}
  class:list={[tight ? "section-tight" : "section", bg, className]}
>
  <slot />
</section>
