---
import Logo from "./ui/Logo.astro";
import Button from "./ui/Button.astro";
import { getContent, resolveLocale, localePath, stripLocale } from "../content/i18n";

const locale = resolveLocale(Astro.url.pathname);
const { nav, site } = getContent(locale);

// Language switcher: this page in each language. The 404 page has no RO
// counterpart (GitHub Pages serves a single /404.html), so fall back to home.
let barePath = stripLocale(Astro.url.pathname);
if (barePath === "/404") barePath = "/";
const langLinks = [
  { code: "EN", locale: "en" as const, href: localePath("en", barePath) },
  { code: "RO", locale: "ro" as const, href: localePath("ro", barePath) },
];
const homeHref = locale === "ro" ? "/ro" : "/";
const menuLabel = locale === "ro" ? "Deschide meniul" : "Open menu";
const langNavLabel = locale === "ro" ? "Limbă" : "Language";
---

<header data-header class="site-header">
  <div class="container-lt header-inner">
    <a href={homeHref} class="header-logo" aria-label={`${site.name} — home`}>
      <Logo variant="primary" height={48} eager responsive alt={site.name} />
    </a>

    <nav class="header-nav" aria-label="Primary">
      <ul class="header-links">
        {
          nav.map((item) => (
            <li>
              <a
                href={item.href}
                class="header-link"
                data-nav-link={item.href.includes("#") ? "" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="lang-switch" role="navigation" aria-label={langNavLabel}>
        {
          langLinks.map((l) => (
            <a
              href={l.href}
              class:list={["lang-link", { "is-current": l.locale === locale }]}
              aria-current={l.locale === locale ? "true" : undefined}
              lang={l.locale}
            >
              {l.code}
            </a>
          ))
        }
      </div>
      <Button href={site.primaryCta.href} external={site.primaryCta.external}>
        {site.primaryCta.label}
      </Button>
    </nav>

    <button
      type="button"
      data-menu-toggle
      class="menu-toggle"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label={menuLabel}
    >
      <span class="menu-bars" aria-hidden="true"></span>
      <span class="sr-only">{locale === "ro" ? "Meniu" : "Menu"}</span>
    </button>
  </div>

  <div id="mobile-menu" data-menu-panel class="menu-panel" hidden>
    <nav class="menu-nav" aria-label={locale === "ro" ? "Meniu mobil" : "Mobile"}>
      <ul>
        {
          nav.map((item) => (
            <li>
              <a href={item.href} class="menu-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
      <div class="lang-switch lang-switch--menu" role="navigation" aria-label={langNavLabel}>
        {
          langLinks.map((l) => (
            <a
              href={l.href}
              class:list={["lang-link", { "is-current": l.locale === locale }]}
              aria-current={l.locale === locale ? "true" : undefined}
              lang={l.locale}
            >
              {l.code}
            </a>
          ))
        }
      </div>
      <div class="menu-cta">
        <Button
          href={site.primaryCta.href}
          external={site.primaryCta.external}
          withArrow>{site.primaryCta.label}</Button
        >
      </div>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background-color 0.25s var(--ease-out-soft),
      border-color 0.25s var(--ease-out-soft),
      box-shadow 0.25s var(--ease-out-soft);
  }
  /* Subtly more solid once the page is scrolled (brief §5) */
  .site-header.is-scrolled {
    background-color: color-mix(in srgb, var(--color-paper) 92%, transparent);
    -webkit-backdrop-filter: saturate(1.1);
    backdrop-filter: saturate(1.1);
    border-bottom-color: var(--color-line);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    min-height: var(--spacing-header);
    gap: 1.5rem;
  }
  /* Taller header on laptop/desktop to give the larger logo room to breathe */
  @media (min-width: 900px) {
    .header-inner {
      min-height: 5.25rem; /* 84px */
    }
  }

  .header-logo {
    display: inline-flex;
    align-items: center;
    flex-shrink: 0;
    border-radius: 4px;
  }

  .header-nav {
    display: none;
    align-items: center;
    gap: clamp(1.25rem, 2.5vw, 2.25rem);
  }

  .header-links {
    display: flex;
    align-items: center;
    gap: clamp(1rem, 2vw, 2rem);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .header-link {
    position: relative;
    display: inline-flex;
    align-items: center;
    min-height: 44px; /* comfortable touch target */
    color: var(--color-ink);
    font-size: 0.9375rem; /* 15 */
    font-weight: 500;
    text-decoration: none;
    letter-spacing: 0.005em;
    transition: color 0.18s var(--ease-out-soft);
  }
  .header-link::after {
    content: "";
    position: absolute;
    left: 0;
    bottom: 9px;
    width: 100%;
    height: 2px;
    background-color: var(--color-steel);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.22s var(--ease-out-soft);
  }
  .header-link:hover {
    color: var(--color-steel-deep);
  }
  .header-link.is-active {
    color: var(--color-steel-deep);
  }
  .header-link.is-active::after,
  .header-link:hover::after {
    transform: scaleX(1);
  }

  /* Language switcher */
  .lang-switch {
    display: inline-flex;
    align-items: center;
    gap: 0.125rem;
    padding: 0.125rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
  }
  .lang-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.125rem;
    padding: 0.3125rem 0.5rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--color-muted);
    text-decoration: none;
    transition:
      color 0.18s var(--ease-out-soft),
      background-color 0.18s var(--ease-out-soft);
  }
  .lang-link:hover {
    color: var(--color-steel-deep);
  }
  .lang-link.is-current {
    background-color: var(--color-ink);
    color: var(--color-paper);
  }
  .lang-switch--menu {
    align-self: flex-start;
    margin-top: 1.25rem;
  }

  /* Hamburger toggle */
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    margin-right: -0.5rem;
    background: transparent;
    border: 0;
    cursor: pointer;
    border-radius: 8px;
  }
  .menu-bars,
  .menu-bars::before,
  .menu-bars::after {
    display: block;
    width: 22px;
    height: 2px;
    background-color: var(--color-ink);
    border-radius: 2px;
    transition: transform 0.24s var(--ease-out-soft),
      opacity 0.18s var(--ease-out-soft);
  }
  .menu-bars {
    position: relative;
  }
  .menu-bars::before,
  .menu-bars::after {
    content: "";
    position: absolute;
    left: 0;
  }
  .menu-bars::before {
    top: -7px;
  }
  .menu-bars::after {
    top: 7px;
  }
  [data-menu-toggle][aria-expanded="true"] .menu-bars {
    background-color: transparent;
  }
  [data-menu-toggle][aria-expanded="true"] .menu-bars::before {
    transform: translateY(7px) rotate(45deg);
  }
  [data-menu-toggle][aria-expanded="true"] .menu-bars::after {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu panel */
  .menu-panel {
    border-top: 1px solid var(--color-line);
    border-bottom: 1px solid var(--color-line);
    background-color: var(--color-paper);
    overflow: hidden;
    max-height: 0;
    opacity: 0;
    transition:
      max-height 0.3s var(--ease-out-soft),
      opacity 0.25s var(--ease-out-soft);
  }
  .menu-panel.is-open {
    max-height: 80vh;
    opacity: 1;
  }
  .menu-nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding: 1rem clamp(1.25rem, 5vw, 2.5rem) 1.75rem;
  }
  .menu-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }
  .menu-link {
    display: block;
    padding: 0.875rem 0;
    color: var(--color-ink);
    font-size: 1.125rem;
    font-weight: 500;
    text-decoration: none;
    border-bottom: 1px solid var(--color-line);
  }
  .menu-link:hover {
    color: var(--color-steel-deep);
  }
  /* grid wrapper so the CTA anchor stretches to full width on mobile */
  .menu-cta {
    display: grid;
    margin-top: 1.25rem;
  }
  /* Desktop: show inline nav, hide the hamburger + mobile panel.
     Placed last so these overrides win over the base rules above. */
  @media (min-width: 900px) {
    .header-nav {
      display: flex;
    }
    .menu-toggle {
      display: none;
    }
    .menu-panel {
      display: none;
    }
  }
</style>
