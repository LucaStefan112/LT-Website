---
import Base from "../layouts/Base.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Container from "../components/ui/Container.astro";
import { pageMeta, site } from "../content/site";

const meta = pageMeta.terms;
---

<Base title={meta.title} description={meta.description} path={meta.path}>
  <PageIntro
    eyebrow="Legal"
    title="Terms of use."
    lead="The basis on which this website is provided. A short, plain starting point."
    headingId="terms-heading"
  />

  <section class="legal-section bg-paper" aria-label="Terms of use">
    <Container>
      <div class="prose legal-prose">
        <p class="legal-updated">Last updated: 3 July 2026</p>

        <h2>About this site</h2>
        <p>
          This website is published by {site.name} to describe our services and
          share our thinking. It is provided for general information only.
        </p>

        <h2>No advice or contract</h2>
        <p>
          Nothing on this website is professional, legal, financial, or
          technical advice, and nothing here forms a contract or an engagement.
          Any work we do together is governed by a separate written agreement
          agreed with you in advance.
        </p>

        <h2>Intellectual property</h2>
        <p>
          The content, brand, and design of this website belong to {site.name}
          unless stated otherwise. Product names and marks referenced in our
          work belong to their respective owners.
        </p>

        <h2>Links</h2>
        <p>
          Where this site links to external sites, we are not responsible for
          their content or their practices.
        </p>

        <h2>Contact</h2>
        <p>
          Questions about these terms? Email
          <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>

        <p>
          These terms are a concise starting point and may be extended as the
          business grows. For any engagement, a separate written agreement takes
          precedence.
        </p>
      </div>
    </Container>
  </section>
</Base>

<style>
  .legal-section {
    padding-bottom: clamp(4.5rem, 9vw, 7rem);
  }
  .legal-prose {
    margin-inline: auto;
  }
  .legal-updated {
    font-size: 0.875rem;
    color: var(--color-muted);
  }
  .legal-verify {
    padding: 0.875rem 1.1rem;
    border-left: 2px solid var(--color-steel);
    background-color: color-mix(in srgb, var(--color-steel) 5%, var(--color-paper));
    font-style: italic;
    font-size: 0.9375rem;
  }
</style>
