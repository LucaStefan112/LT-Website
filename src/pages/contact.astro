---
import Base from "../layouts/Base.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Container from "../components/ui/Container.astro";
import ContactForm from "../components/sections/ContactForm.astro";
import { pageMeta, pageIntros, contact } from "../content/site";

const meta = pageMeta.contact;
const intro = pageIntros.contact;
---

<Base title={meta.title} description={meta.description} path={meta.path}>
  <PageIntro
    eyebrow={intro.eyebrow}
    title={intro.title}
    lead={intro.lead}
    headingId="contact-page-heading"
  />

  <section class="contact-section bg-paper" aria-label="Contact details and form">
    <Container>
      <div class="contact-layout">
        <aside class="contact-aside">
          <h2 class="eyebrow">Direct line</h2>
          <span class="rule" aria-hidden="true"></span>
          <p class="contact-aside-lead">
            Prefer email, or want to reach us straight away?
          </p>
          <a href={`mailto:${contact.email}`} class="contact-email">
            {contact.email}
          </a>
          <ul class="contact-points" role="list">
            <li>Independent, senior-led advice.</li>
            <li>A reply within two business days.</li>
            <li>No sales script, no pressure.</li>
          </ul>
          <p class="contact-location">{contact.location}</p>
        </aside>

        <div class="contact-form-col">
          <ContactForm />
          <p class="contact-privacy">
            We only use your details to reply to your enquiry, and never share
            them with third parties. See our <a href="/privacy">privacy policy</a>.
          </p>
        </div>
      </div>
    </Container>
  </section>
</Base>

<style>
  .contact-section {
    padding-bottom: clamp(4.5rem, 9vw, 8rem);
  }
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .contact-layout {
      grid-template-columns: 0.8fr 1.2fr;
      gap: clamp(3rem, 6vw, 5rem);
    }
  }
  .contact-aside-lead {
    margin-top: 1.5rem;
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.6;
    max-width: 34ch;
  }
  .contact-email {
    display: inline-block;
    margin-top: 1rem;
    color: var(--color-steel);
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    max-width: 100%;
    overflow-wrap: anywhere;
  }
  .contact-email:hover {
    color: var(--color-steel-deep);
    text-decoration: underline;
  }
  .contact-points {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .contact-points li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--color-muted);
    font-size: 1rem;
  }
  .contact-points li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.6em;
    width: 1rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .contact-location {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.9375rem;
    color: var(--color-muted);
    max-width: 30ch;
  }
  .contact-privacy {
    margin-top: 1.5rem;
    font-size: 0.8125rem;
    color: var(--color-muted);
  }
  .contact-privacy a {
    color: var(--color-steel);
  }
</style>
