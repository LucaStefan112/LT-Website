---
import Base from "../layouts/Base.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import Container from "../components/ui/Container.astro";
import { site } from "../content/site";
---

<Base
  title="Privacy — LT Strategy Partners"
  description="How LT Strategy Partners handles the information you share."
  path="/privacy"
>
  <PageIntro
    eyebrow="Legal"
    title="Privacy note."
    lead="A short, plain-English summary of how we handle your information."
    headingId="privacy-heading"
  />
  <section class="legal bg-paper" aria-label="Privacy details">
    <Container>
      <div class="legal-body measure">
        <p class="legal-placeholder">
          [Placeholder — replace with your finalised privacy policy.]
        </p>
        <p>
          We collect only what you choose to send us through the contact form
          (your name, company, role, email, and message) and use it solely to
          reply to your enquiry. We don't sell or share your details, and we
          don't run advertising or invasive tracking on this site.
        </p>
        <p>
          To ask what we hold, or to have it removed, email
          <a href={`mailto:${site.email}`}>{site.email}</a>.
        </p>
      </div>
    </Container>
  </section>
</Base>

<style>
  .legal {
    padding-bottom: clamp(4.5rem, 9vw, 7rem);
  }
  .legal-body p {
    margin-bottom: 1.25rem;
    color: var(--color-muted);
    line-height: 1.7;
  }
  .legal-placeholder {
    padding: 1rem 1.25rem;
    border-left: 2px solid var(--color-steel);
    color: var(--color-muted);
    font-style: italic;
  }
  .legal-body a {
    color: var(--color-steel);
  }
</style>
