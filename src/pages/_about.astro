---
import Base from "../layouts/Base.astro";
import PageIntro from "../components/sections/PageIntro.astro";
import About from "../components/sections/About.astro";
import Statement from "../components/sections/Statement.astro";
import CTABand from "../components/sections/CTABand.astro";
import { pageMeta, pageIntros } from "../content/site";

const meta = pageMeta.about;
const intro = pageIntros.about;
---

<Base title={meta.title} description={meta.description} path={meta.path}>
  <PageIntro
    eyebrow={intro.eyebrow}
    title={intro.title}
    lead={intro.lead}
    headingId="about-page-heading"
  />
  <About />
  <Statement />
  <CTABand />
</Base>
