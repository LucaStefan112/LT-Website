---
import Base from "../layouts/Base.astro";
import Container from "../components/ui/Container.astro";
import Button from "../components/ui/Button.astro";
import AssessmentForm from "../components/sections/AssessmentForm.astro";
import { getContent } from "../content/i18n";

const { pageMeta, assessmentPage: page } = getContent(Astro.url.pathname);
const meta = pageMeta.assessment;
---

<Base title={meta.title} description={meta.description} path={meta.path}>
  <!-- 1 · Hero -->
  <section class="az-hero bg-paper" aria-labelledby="az-heading">
    <Container>
      <p class="eyebrow">{page.eyebrow}</p>
      <span class="rule" aria-hidden="true"></span>
      <h1 id="az-heading" class="display-lg az-hero-title">{page.heading}</h1>
      <p class="lead az-hero-lead measure">{page.lead}</p>
      <div class="az-hero-cta">
        <Button href={page.heroCta.href} withArrow>{page.heroCta.label}</Button>
      </div>
      <ul class="az-hero-facts" role="list">
        {page.heroFacts.map((f) => <li>{f}</li>)}
      </ul>
    </Container>
  </section>

  <!-- 2 · The problem -->
  <section class="az-problem bg-bone" aria-labelledby="az-problem-heading">
    <Container>
      <div class="az-narrow">
        <p class="eyebrow">{page.problem.eyebrow}</p>
        <span class="rule" aria-hidden="true"></span>
        <h2 id="az-problem-heading" class="section-title az-block-title">
          {page.problem.heading}
        </h2>
        {page.problem.paragraphs.map((p) => <p class="az-para">{p}</p>)}
      </div>
    </Container>
  </section>

  <!-- 3 · What you get -->
  <section class="az-deliverable bg-paper" aria-labelledby="az-deliverable-heading">
    <Container>
      <div class="az-split">
        <div class="az-split-lead">
          <p class="eyebrow">{page.deliverable.eyebrow}</p>
          <span class="rule" aria-hidden="true"></span>
          <h2 id="az-deliverable-heading" class="section-title az-block-title">
            {page.deliverable.heading}
          </h2>
          <p class="az-para">{page.deliverable.intro}</p>
          <div class="az-guarantee">
            <p class="az-guarantee-label">The written guarantee</p>
            <p class="az-guarantee-text">{page.deliverable.guarantee}</p>
          </div>
          <a href={page.deliverable.sampleCta.href} class="link-arrow az-sample-link" data-astro-prefetch>
            {page.deliverable.sampleCta.label}
            <span class="arrow" aria-hidden="true">
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                <path d="M3 8h9M8.5 4l3.5 4-3.5 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </span>
          </a>
        </div>
        <ul class="az-deliverable-list card" role="list">
          {page.deliverable.items.map((item) => <li>{item}</li>)}
        </ul>
      </div>
    </Container>
  </section>

  <!-- 4 · The method (dark band — the centerpiece) -->
  <section class="az-method band-ink on-dark" aria-labelledby="az-method-heading">
    <Container>
      <p class="eyebrow az-method-eyebrow">{page.method.eyebrow}</p>
      <span class="rule" aria-hidden="true"></span>
      <h2 id="az-method-heading" class="section-title az-method-title">
        {page.method.heading}
      </h2>
      <p class="az-method-intro">{page.method.intro}</p>

      <ol class="az-dimensions" role="list">
        {
          page.method.dimensions.map((d, i) => (
            <li class="az-dimension">
              <span class="az-dim-index">{String(i + 1).padStart(2, "0")}</span>
              <h3 class="az-dim-name">{d.name}</h3>
              <p class="az-dim-desc">{d.desc}</p>
            </li>
          ))
        }
      </ol>

      <div class="az-method-foot">
        <div class="az-rules">
          <p class="az-foot-label">Three rules, stated in every readout</p>
          <ul role="list">
            {page.method.rules.map((r) => <li>{r}</li>)}
          </ul>
        </div>
        <div class="az-questions">
          <p class="az-foot-label">Four of the actual gate questions</p>
          <ul role="list">
            {page.method.gateQuestions.map((q) => <li>“{q}”</li>)}
          </ul>
        </div>
      </div>
      <p class="az-standards">{page.method.standardsNote}</p>
    </Container>
  </section>

  <!-- 5 · How it runs -->
  <section class="az-process bg-paper" aria-labelledby="az-process-heading">
    <Container>
      <p class="eyebrow">{page.process.eyebrow}</p>
      <span class="rule" aria-hidden="true"></span>
      <h2 id="az-process-heading" class="section-title az-block-title">
        {page.process.heading}
      </h2>
      <ol class="az-steps" role="list">
        {
          page.process.steps.map((s, i) => (
            <li class="az-step">
              <div class="az-step-head">
                <span class="az-step-num">{i + 1}</span>
                <h3 class="az-step-name">{s.name}</h3>
                <span class="az-step-time">{s.time}</span>
              </div>
              <p class="az-step-desc">{s.desc}</p>
            </li>
          ))
        }
      </ol>
    </Container>
  </section>

  <!-- 6 · Why it's free -->
  <section class="az-free bg-bone" aria-labelledby="az-free-heading">
    <Container>
      <div class="az-narrow">
        <p class="eyebrow">{page.whyFree.eyebrow}</p>
        <span class="rule" aria-hidden="true"></span>
        <h2 id="az-free-heading" class="section-title az-block-title">
          {page.whyFree.heading}
        </h2>
        <p class="az-para">{page.whyFree.body}</p>
        <div class="az-branches">
          {
            page.whyFree.branches.map((b) => (
              <div class="az-branch card">
                <h3 class="az-branch-name">{b.name}</h3>
                <p class="az-branch-desc">{b.desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </Container>
  </section>

  <!-- 7 · Fit -->
  <section class="az-fit bg-paper" aria-labelledby="az-fit-heading">
    <Container>
      <p class="eyebrow">{page.fit.eyebrow}</p>
      <span class="rule" aria-hidden="true"></span>
      <h2 id="az-fit-heading" class="section-title az-block-title">{page.fit.heading}</h2>
      <div class="az-fit-cols">
        <div class="az-fit-col">
          <h3 class="az-fit-label">This is for you if</h3>
          <ul role="list">
            {page.fit.forWho.map((f) => <li>{f}</li>)}
          </ul>
        </div>
        <div class="az-fit-col az-fit-col-not">
          <h3 class="az-fit-label">It isn't if</h3>
          <ul role="list">
            {page.fit.notForWho.map((f) => <li>{f}</li>)}
          </ul>
        </div>
      </div>
    </Container>
  </section>

  <!-- 8 · Who runs it -->
  <section class="az-who bg-bone" aria-labelledby="az-who-heading">
    <Container>
      <div class="az-narrow">
        <p class="eyebrow">{page.whoRuns.eyebrow}</p>
        <span class="rule" aria-hidden="true"></span>
        <h2 id="az-who-heading" class="section-title az-block-title az-who-title">
          “{page.whoRuns.heading}”
        </h2>
        <ul class="az-who-facts" role="list">
          {page.whoRuns.facts.map((f) => <li>{f}</li>)}
        </ul>
        <a href={page.whoRuns.link.href} class="link-arrow" data-astro-prefetch>
          {page.whoRuns.link.label}
          <span class="arrow" aria-hidden="true">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
              <path d="M3 8h9M8.5 4l3.5 4-3.5 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      </div>
    </Container>
  </section>

  <!-- 9 · Positioning strip -->
  <section class="az-positioning band-ink on-dark" aria-labelledby="az-pos-heading">
    <Container>
      <div class="az-narrow">
        <h2 id="az-pos-heading" class="az-pos-title">{page.positioning.heading}</h2>
        <p class="az-pos-body">{page.positioning.body}</p>
        <p class="az-pos-lockin">{page.positioning.noLockIn}</p>
      </div>
    </Container>
  </section>

  <!-- 10 · Apply -->
  <section id="apply" class="az-apply bg-paper" aria-labelledby="az-apply-heading">
    <Container>
      <div class="az-apply-layout">
        <div class="az-apply-lead">
          <p class="eyebrow">{page.apply.eyebrow}</p>
          <span class="rule" aria-hidden="true"></span>
          <h2 id="az-apply-heading" class="section-title az-block-title">
            {page.apply.heading}
          </h2>
          <p class="az-para">{page.apply.intro}</p>
          <p class="az-apply-microcopy">{page.apply.microcopy}</p>
        </div>
        <div class="az-apply-form">
          <AssessmentForm />
        </div>
      </div>
    </Container>
  </section>
</Base>

<style>
  /* ---------- shared ---------- */
  .az-narrow {
    max-width: 46rem;
  }
  .az-block-title {
    margin-top: 1.25rem;
    max-width: 24ch;
  }
  .az-para {
    margin-top: 1.25rem;
    color: var(--color-muted);
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 62ch;
  }

  /* ---------- 1 · hero ---------- */
  .az-hero {
    padding-top: clamp(5.5rem, 11vw, 8.5rem);
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .az-hero-title {
    margin-top: 1.5rem;
    max-width: 22ch;
  }
  .az-hero-lead {
    margin-top: 1.5rem;
  }
  .az-hero-cta {
    margin-top: 2rem;
  }
  .az-hero-facts {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.75rem;
  }
  .az-hero-facts li {
    position: relative;
    font-size: 0.9375rem;
    color: var(--color-muted);
  }
  /* Dot separators only where the facts sit on one line */
  @media (min-width: 640px) {
    .az-hero-facts li + li::before {
      content: "·";
      position: absolute;
      left: -1.125rem;
      color: var(--color-line);
    }
  }

  /* ---------- 2 · problem ---------- */
  .az-problem {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }

  /* ---------- 3 · deliverable ---------- */
  .az-deliverable {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }
  .az-split {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .az-split {
      grid-template-columns: 1.05fr 0.95fr;
    }
  }
  .az-guarantee {
    margin-top: 2rem;
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    border-left: 3px solid var(--color-steel);
    border-radius: 12px;
    background-color: color-mix(in srgb, var(--color-steel) 6%, var(--color-paper));
  }
  .az-guarantee-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-steel);
    margin-bottom: 0.625rem;
  }
  .az-guarantee-text {
    color: var(--color-ink);
    font-size: 1rem;
    line-height: 1.6;
  }
  .az-sample-link {
    margin-top: 1.75rem;
    display: inline-flex;
  }
  .az-deliverable-list {
    list-style: none;
    margin: 0;
    padding: clamp(1.5rem, 3vw, 2.25rem);
    display: flex;
    flex-direction: column;
    gap: 1.125rem;
  }
  .az-deliverable-list li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--color-ink);
    font-size: 1rem;
    line-height: 1.55;
  }
  .az-deliverable-list li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 1rem;
    height: 2px;
    background-color: var(--color-steel);
  }

  /* ---------- 4 · method (dark) ---------- */
  .az-method {
    padding-block: clamp(4.5rem, 9vw, 7rem);
  }
  .az-method-eyebrow {
    color: var(--color-steel-bright);
  }
  .az-method-title {
    margin-top: 1.25rem;
    color: #fff;
    max-width: 26ch;
  }
  .az-method-intro {
    margin-top: 1.25rem;
    color: color-mix(in srgb, var(--color-bone) 82%, transparent);
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 62ch;
  }
  .az-dimensions {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.75rem 2.5rem;
  }
  @media (min-width: 640px) {
    .az-dimensions {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (min-width: 1024px) {
    .az-dimensions {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  .az-dimension {
    padding-top: 1rem;
    border-top: 1px solid var(--color-line-dark);
  }
  .az-dim-index {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    color: var(--color-steel-bright);
  }
  .az-dim-name {
    margin-top: 0.5rem;
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--color-bone);
  }
  .az-dim-desc {
    margin-top: 0.375rem;
    font-size: 0.9375rem;
    line-height: 1.55;
    color: color-mix(in srgb, var(--color-bone) 70%, transparent);
  }
  .az-method-foot {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 3rem;
    margin-top: clamp(2.5rem, 5vw, 3.5rem);
    padding-top: 2rem;
    border-top: 1px solid var(--color-line-dark);
  }
  @media (min-width: 768px) {
    .az-method-foot {
      grid-template-columns: 1fr 1fr;
    }
  }
  .az-foot-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-steel-bright);
    margin-bottom: 1rem;
  }
  .az-rules ul,
  .az-questions ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .az-rules li,
  .az-questions li {
    position: relative;
    padding-left: 1.625rem;
    color: color-mix(in srgb, var(--color-bone) 82%, transparent);
    font-size: 0.9688rem;
    line-height: 1.55;
  }
  .az-rules li::before,
  .az-questions li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 0.875rem;
    height: 2px;
    background-color: var(--color-steel-bright);
  }
  .az-questions li {
    font-style: italic;
  }
  .az-standards {
    margin-top: 2rem;
    font-size: 0.875rem;
    line-height: 1.6;
    color: color-mix(in srgb, var(--color-bone) 58%, transparent);
    max-width: 62ch;
  }

  /* ---------- 5 · process ---------- */
  .az-process {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }
  .az-steps {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 2.5rem;
  }
  @media (min-width: 768px) {
    .az-steps {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .az-step {
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    position: relative;
  }
  .az-step::before {
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 2.5rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .az-step-head {
    display: flex;
    align-items: baseline;
    gap: 0.875rem;
    flex-wrap: wrap;
  }
  .az-step-num {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-steel);
  }
  .az-step-name {
    font-size: 1.1875rem;
    font-weight: 600;
    color: var(--color-ink);
  }
  .az-step-time {
    font-size: 0.8125rem;
    color: var(--color-muted);
    border: 1px solid var(--color-line);
    border-radius: 999px;
    padding: 0.125rem 0.625rem;
  }
  .az-step-desc {
    margin-top: 0.75rem;
    color: var(--color-muted);
    font-size: 0.9688rem;
    line-height: 1.6;
    max-width: 48ch;
  }

  /* ---------- 6 · why free ---------- */
  .az-free {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }
  .az-branches {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    margin-top: 2rem;
  }
  @media (min-width: 640px) {
    .az-branches {
      grid-template-columns: 1fr 1fr;
    }
  }
  .az-branch {
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
  }
  .az-branch-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-steel-deep);
    margin-bottom: 0.5rem;
  }
  .az-branch-desc {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-muted);
  }

  /* ---------- 7 · fit ---------- */
  .az-fit {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }
  .az-fit-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem 3.5rem;
    margin-top: clamp(2rem, 4vw, 3rem);
  }
  @media (min-width: 768px) {
    .az-fit-cols {
      grid-template-columns: 1fr 1fr;
    }
  }
  .az-fit-label {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-steel);
    padding-top: 0.875rem;
    border-top: 2px solid var(--color-steel);
    display: inline-block;
    margin-bottom: 1.25rem;
  }
  .az-fit-col-not .az-fit-label {
    color: var(--color-muted);
    border-top-color: var(--color-line);
  }
  .az-fit-col ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .az-fit-col li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--color-ink);
    font-size: 1rem;
    line-height: 1.55;
  }
  .az-fit-col li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 1rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .az-fit-col-not li {
    color: var(--color-muted);
  }
  .az-fit-col-not li::before {
    background-color: var(--color-muted);
  }

  /* ---------- 8 · who runs it ---------- */
  .az-who {
    padding-block: clamp(4rem, 8vw, 6.5rem);
  }
  .az-who-title {
    font-style: italic;
    font-weight: 500;
  }
  .az-who-facts {
    list-style: none;
    margin: 2rem 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  .az-who-facts li {
    position: relative;
    padding-left: 1.75rem;
    color: var(--color-ink);
    font-size: 1.0313rem;
    line-height: 1.55;
  }
  .az-who-facts li::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 1rem;
    height: 2px;
    background-color: var(--color-steel);
  }
  .az-who .link-arrow {
    margin-top: 1.75rem;
    display: inline-flex;
  }

  /* ---------- 9 · positioning ---------- */
  .az-positioning {
    padding-block: clamp(4rem, 8vw, 6rem);
  }
  .az-pos-title {
    font-size: clamp(1.5rem, 3.2vw, 2.125rem);
    font-weight: 600;
    letter-spacing: -0.015em;
    color: #fff;
    max-width: 22ch;
  }
  .az-pos-body {
    margin-top: 1.25rem;
    color: color-mix(in srgb, var(--color-bone) 80%, transparent);
    font-size: 1.0625rem;
    line-height: 1.65;
    max-width: 62ch;
  }
  .az-pos-lockin {
    margin-top: 1.5rem;
    color: var(--color-steel-bright);
    font-weight: 500;
    font-size: 1.0625rem;
  }

  /* ---------- 10 · apply ---------- */
  .az-apply {
    padding-block: clamp(4rem, 8vw, 6.5rem) clamp(4.5rem, 9vw, 8rem);
    scroll-margin-top: 5rem;
  }
  .az-apply-layout {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  @media (min-width: 900px) {
    .az-apply-layout {
      grid-template-columns: 0.8fr 1.2fr;
    }
  }
  .az-apply-microcopy {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid var(--color-line);
    font-size: 0.875rem;
    color: var(--color-muted);
  }
</style>
